    "t": "bun run test",
    "c": "bun run compile"
  },
  "dependencies": {
    "express": "5.2.1",
    "karse-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "@types/express": "5.0.6",
    "@types/node": "22.19.19",
    "@types/jest": "29.5.14",
    "jest": "29.7.0",
    "@swc/jest": "0.2.39",
    "@swc/core": "1.15.40"
  }
}
